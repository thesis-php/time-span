{
    "name": "thesis/time-span",
    "description": "Thesis TimeSpan",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Valentin Udaltsov",
            "email": "udaltsov.valentin@gmail.com"
        },
        {
            "name": "Thesis Team",
            "homepage": "https://github.com/orgs/thesis-php/people"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.1.4",
        "symfony/var-dumper": "^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Thesis\\": "src/"
        },
        "files": [
            "src/Time/TimeSpan.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Thesis\\": "tests/"
        }
    },
    "config": {
        "lock": false,
        "sort-packages": true
    }
}
